<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Wingnal.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Wingnal"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Wingnal">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="F" Invoked="OnSearchAccelerator" />
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar: app icon + title + a contact search box (per the MS "search box in the
             title bar" pattern). The whole bar is the drag region via SetTitleBar; interactive children
             like the search box are automatically excluded from dragging. Caption buttons sit on the
             right, so the search is constrained well clear of them. -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Source="ms-appx:///Assets/Square44x44Logo.scale-200.png"
                   Width="18" Height="18" Margin="14,0,0,0"
                   VerticalAlignment="Center" AutomationProperties.AccessibilityView="Raw" />
            <TextBlock Grid.Column="1" x:Name="AppTitleText" Text="Wingnal"
                       VerticalAlignment="Center" Margin="10,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}" />
            <AutoSuggestBox Grid.Column="2" x:Name="TitleSearch"
                            Visibility="Collapsed"
                            HorizontalAlignment="Stretch" VerticalAlignment="Center"
                            MaxWidth="460" Height="32" Margin="24,0"
                            AutomationProperties.Name="Search contacts"
                            PlaceholderText="Search contacts…" QueryIcon="Find"
                            DisplayMemberPath="Display" TextMemberPath="Display"
                            TextChanged="OnTitleSearchTextChanged"
                            SuggestionChosen="OnTitleSearchSuggestionChosen"
                            QuerySubmitted="OnTitleSearchQuerySubmitted" />
        </Grid>

        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
