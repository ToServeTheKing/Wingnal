<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Wingnal.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Wingnal"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Thread items: a message bubble or a day divider, chosen by ChatItemTemplateSelector. -->
        <DataTemplate x:Key="MessageBubbleTemplate" x:DataType="local:MessageItem">
            <StackPanel Margin="{x:Bind BubbleMargin}" Spacing="2" HorizontalAlignment="{x:Bind Alignment}">
                <StackPanel.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Copy" Click="OnCopyMessage">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Delete" Click="OnDeleteMessage">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </StackPanel.ContextFlyout>
                <Border Background="{x:Bind BubbleBrush}" CornerRadius="{x:Bind BubbleCorner}"
                        Padding="12,8" MaxWidth="460">
                    <StackPanel Spacing="6">
                        <!-- Inline image for image attachments; non-image media falls back to the text label. -->
                        <Image Source="{x:Bind ImageSource}" Visibility="{x:Bind ImageVisibility}"
                               MaxWidth="320" MaxHeight="320" Stretch="Uniform" />
                        <TextBlock Text="{x:Bind Body}" TextWrapping="Wrap" Visibility="{x:Bind BodyVisibility}"
                                   IsTextSelectionEnabled="True" Foreground="{x:Bind Foreground}">
                            <!-- On the text itself, override the default "Select All" menu with ours. -->
                            <TextBlock.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Copy" Click="OnCopyMessage">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem Text="Delete" Click="OnDeleteMessage">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </TextBlock.ContextFlyout>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <TextBlock Text="{x:Bind Caption, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{x:Bind CaptionBrush, Mode=OneWay}"
                           Visibility="{x:Bind CaptionVisibility, Mode=OneWay}"
                           Margin="4,0" HorizontalAlignment="{x:Bind Alignment}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="DaySeparatorTemplate" x:DataType="local:DaySeparatorItem">
            <Border HorizontalAlignment="Center" Margin="0,10"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}" CornerRadius="10" Padding="12,3">
                <TextBlock Text="{x:Bind Label}" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Border>
        </DataTemplate>

        <local:ChatItemTemplateSelector x:Key="ChatItemSelector"
                                        MessageTemplate="{StaticResource MessageBubbleTemplate}"
                                        SeparatorTemplate="{StaticResource DaySeparatorTemplate}" />
    </Page.Resources>

    <Grid ColumnSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="300" />
            <ColumnDefinition x:Name="ThreadColumn" Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ════ Conversation sidebar ════ -->
        <Grid x:Name="SidebarPane" Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderThickness="0,0,1,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              Padding="6,8,6,12" RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Chats" Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center" Padding="4,0,0,0" />
                <Button Grid.Column="1" x:Name="NewChatButton" Click="OnNewChatClick"
                        Width="34" Height="34" Padding="0" CornerRadius="8"
                        ToolTipService.ToolTip="New chat" AutomationProperties.Name="New chat">
                    <FontIcon Glyph="&#xE710;" FontSize="16" />
                    <Button.Resources>
                        <TeachingTip x:Name="NewChatTip" Target="{x:Bind NewChatButton}"
                                     Title="Start a conversation"
                                     Subtitle="Tap ＋ here, or use the search box in the title bar, to message a contact." />
                    </Button.Resources>
                </Button>
            </Grid>

            <!-- Right padding reserves a gutter so the scrollbar doesn't overlap the rows. -->
            <ListView Grid.Row="1" x:Name="ConversationList" SelectionMode="Single"
                      SelectionChanged="OnConversationSelected" Padding="0,2,8,2">
                <ListView.ItemContainerStyle>
                    <!-- The container is a bare, transparent content host: the row's own fill (hover/
                         selected) is drawn by the Border in the item template, so it always wraps the
                         whole row. Margin is the gap between rows; the row's inner padding lives on that
                         Border. Stretch so the Border fills the full row width. -->
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,2" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter Background="Transparent"
                                        Content="{TemplateBinding Content}"
                                        ContentTemplate="{TemplateBinding ContentTemplate}"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:ConversationItem">
                        <!-- This Border is the row fill: it wraps every component, so the hover/selected
                             grey always contains the avatar, text, time and unread dot. -->
                        <Border Background="{x:Bind RowBackground, Mode=OneWay}" CornerRadius="8"
                                Padding="12,10"
                                PointerEntered="OnConversationPointerEntered"
                                PointerExited="OnConversationPointerExited">
                        <Grid ColumnSpacing="12">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Mark as read" Click="OnMarkConversationRead" />
                                    <MenuFlyoutItem Text="Delete conversation" Click="OnDeleteConversation" />
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                    Background="{x:Bind AvatarBrush}" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Glyph, Mode=OneWay}" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" Foreground="{ThemeResource AvatarForegroundBrush}"
                                           FontSize="16" FontWeight="SemiBold" />
                            </Border>
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                               FontWeight="{x:Bind TitleFontWeight, Mode=OneWay}"
                                               TextTrimming="CharacterEllipsis" />
                                    <!-- Right-aligned time, then a small accent dot when there are unread messages. -->
                                    <TextBlock Grid.Column="1" Text="{x:Bind TimeLabel, Mode=OneWay}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               VerticalAlignment="Center" />
                                    <Ellipse Grid.Column="2" Width="8" Height="8" VerticalAlignment="Center"
                                             Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                             Visibility="{x:Bind UnreadVisibility, Mode=OneWay}"
                                             ToolTipService.ToolTip="Unread" />
                                </Grid>
                                <TextBlock Text="{x:Bind Preview, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           TextWrapping="NoWrap" MaxLines="1"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- ════ Conversation thread ════ -->
        <Grid x:Name="ThreadPane" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Thread header: (back) + avatar + name + connection status -->
            <Grid Grid.Row="0" Padding="20,14" ColumnSpacing="12"
                  BorderThickness="0,0,0,1" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="BackButton" Grid.Column="0" Click="OnBackClick" Visibility="Collapsed"
                        Width="34" Height="34" Padding="0" Background="Transparent" BorderThickness="0"
                        VerticalAlignment="Center" ToolTipService.ToolTip="Back" AutomationProperties.Name="Back">
                    <FontIcon Glyph="&#xE72B;" FontSize="16" />
                </Button>
                <Border x:Name="ThreadAvatar" Grid.Column="1" Width="36" Height="36" CornerRadius="18"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        VerticalAlignment="Center" Visibility="Collapsed">
                    <TextBlock x:Name="ThreadAvatarText" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{ThemeResource AvatarForegroundBrush}" FontSize="15" FontWeight="SemiBold" />
                </Border>
                <TextBlock x:Name="ThreadTitle" Grid.Column="2" Text="Select or start a conversation"
                           VerticalAlignment="Center"
                           Style="{StaticResource SubtitleTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button x:Name="ThreadMenuButton" Visibility="Collapsed"
                            Width="34" Height="34" Padding="0" Background="Transparent" BorderThickness="0"
                            VerticalAlignment="Center" ToolTipService.ToolTip="More"
                            AutomationProperties.Name="More options">
                        <FontIcon Glyph="&#xE712;" FontSize="16" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Mark as read" Click="OnMarkConversationRead" />
                                <MenuFlyoutItem Text="Delete conversation" Click="OnDeleteConversation" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button x:Name="VerifyButton" Click="OnVerifySafetyNumberClick" Visibility="Collapsed"
                            Width="34" Height="34" Padding="0" Background="Transparent" BorderThickness="0"
                            VerticalAlignment="Center" ToolTipService.ToolTip="View safety number"
                            AutomationProperties.Name="View safety number">
                        <FontIcon Glyph="&#xE72E;" FontSize="16" />
                    </Button>
                    <Ellipse x:Name="ConnectionDot" Width="8" Height="8"
                             Fill="{ThemeResource SystemFillColorCautionBrush}" />
                    <TextBlock x:Name="StatusText" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="Connecting…" />
                </StackPanel>
            </Grid>

            <!-- Transient errors (send/decrypt/connection), with an optional Retry. -->
            <InfoBar x:Name="ErrorBar" Grid.Row="1" IsOpen="False" Severity="Error" IsClosable="True"
                     Margin="20,8,20,0">
                <InfoBar.ActionButton>
                    <Button x:Name="RetryButton" Content="Retry" Click="OnRetryClick" Visibility="Collapsed" />
                </InfoBar.ActionButton>
            </InfoBar>

            <!-- Messages + empty state share this cell -->
            <Grid Grid.Row="2">
                <ListView x:Name="MessageList" SelectionMode="None" IsItemClickEnabled="False"
                          Background="Transparent" Padding="20,12"
                          ItemTemplateSelector="{StaticResource ChatItemSelector}">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- Keep the newest message in view as items stream in, the standard chat behaviour. -->
                            <ItemsStackPanel ItemsUpdatingScrollMode="KeepLastItemInView" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <!-- "<name> is typing…" — floats at the bottom-left of the thread while a peer types. -->
                <Border x:Name="TypingIndicator" Visibility="Collapsed" IsHitTestVisible="False"
                        HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="20,0,0,6"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        CornerRadius="12" Padding="12,6">
                    <TextBlock x:Name="TypingIndicatorText" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Border>

                <!-- Shown when an open conversation has no messages yet. -->
                <TextBlock x:Name="ThreadEmptyHint" Visibility="Collapsed" IsHitTestVisible="False"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           Text="No messages yet. Say hello 👋" />

                <!-- Empty state (hidden once a conversation is open) -->
                <StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Spacing="14" MaxWidth="320">
                    <FontIcon Glyph="&#xE8BD;" FontSize="40" AutomationProperties.AccessibilityView="Raw"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="No conversation selected"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="Pick a chat on the left, or start a new conversation." />
                    <Button Content="New chat" Click="OnNewChatClick" HorizontalAlignment="Center"
                            Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Grid>

            <!-- Compose bar -->
            <Grid Grid.Row="3" Padding="20,12,20,16" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- KeyDown is attached in code-behind with handledEventsToo=true: a multiline TextBox
                     marks Enter's KeyDown handled (to insert the newline) before a XAML handler sees it. -->
                <TextBox Grid.Column="0" x:Name="ComposeBox" IsEnabled="False"
                         PlaceholderText="Type a message…  (Shift+Enter for a new line)"
                         TextChanged="OnComposeTextChanged"
                         AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="120"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         CornerRadius="18" Padding="14,8" VerticalAlignment="Bottom" />
                <Button Grid.Column="1" x:Name="SendButton" Click="OnSendClick"
                        IsEnabled="False" Style="{StaticResource AccentButtonStyle}"
                        Width="40" Height="40" CornerRadius="20" Padding="0"
                        VerticalAlignment="Bottom"
                        ToolTipService.ToolTip="Send" AutomationProperties.Name="Send">
                    <FontIcon Glyph="&#xE724;" FontSize="16" />
                </Button>
            </Grid>
        </Grid>

        <!-- ════ Importing overlay (link'n'sync history backfill) ════ -->
        <Grid x:Name="ImportOverlay" Grid.ColumnSpan="2" Visibility="Collapsed"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16" MaxWidth="380">
                <ProgressRing IsActive="True" Width="56" Height="56" HorizontalAlignment="Center"
                              AutomationProperties.Name="Importing message history" />
                <TextBlock Text="Importing your message history…"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" TextAlignment="Center" />
                <TextBlock x:Name="ImportSubtext" HorizontalAlignment="Center" TextAlignment="Center"
                           TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Waiting for your phone to send the transfer archive. Keep both devices online and unlocked." />
                <Button x:Name="ImportSkipButton" Content="Skip for now" Click="OnSkipImportClick"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
